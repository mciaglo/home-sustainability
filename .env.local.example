# Copy this file to .env.local and fill in values

# Google Maps Platform (Street View Static API) — console.cloud.google.com
GOOGLE_MAPS_API_KEY=

# RVO EP-online API — ep-online.nl
RVO_API_KEY=

# Kadaster BAG API — kadaster.nl
BAG_API_KEY=

# Resend email API — resend.com
RESEND_API_KEY=

# Protect cron endpoint in production
CRON_SECRET=
